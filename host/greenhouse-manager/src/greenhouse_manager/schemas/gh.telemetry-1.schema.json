{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hahub.top/schemas/gh.telemetry-1.schema.json",
  "title": "Greenhouse telemetry message v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "node_id",
    "boot_id",
    "seq",
    "uptime_ms",
    "cap_hash",
    "measurements",
    "quality",
    "power"
  ],
  "properties": {
    "schema": {"const": "gh.telemetry/1"},
    "node_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 64,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "boot_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 64,
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "seq": {"type": "integer", "minimum": 0, "maximum": 4294967295},
    "uptime_ms": {"type": "integer", "minimum": 0},
    "sampled_at": {"type": "string", "format": "date-time"},
    "received_at": {
      "type": "string",
      "format": "date-time",
      "description": "Added only by greenhouse-manager on canonical state topics."
    },
    "cap_hash": {"type": "string", "minLength": 8, "maxLength": 128},
    "fw_version": {"type": "string", "maxLength": 64},
    "measurements": {
      "type": "object",
      "additionalProperties": {"type": ["number", "null"]},
      "properties": {
        "air_temperature_c": {"type": ["number", "null"]},
        "air_humidity_pct": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
        "co2_ppm": {"type": ["number", "null"], "minimum": 0},
        "illuminance_lx": {"type": ["number", "null"], "minimum": 0},
        "soil_temperature_c": {"type": ["number", "null"]},
        "soil_moisture_pct": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
        "soil_ec_us_cm": {"type": ["number", "null"], "minimum": 0},
        "vpd_kpa": {"type": ["number", "null"], "minimum": 0},
        "dew_point_c": {"type": ["number", "null"]},
        "absolute_humidity_g_m3": {"type": ["number", "null"], "minimum": 0},
        "ppfd_umol_m2_s": {"type": ["number", "null"], "minimum": 0},
        "dli_today_mol_m2_d": {"type": ["number", "null"], "minimum": 0},
        "dli_yesterday_mol_m2_d": {"type": ["number", "null"], "minimum": 0},
        "battery_v": {"type": ["number", "null"], "minimum": 0},
        "battery_pct": {"type": ["number", "null"], "minimum": 0, "maximum": 100}
      }
    },
    "quality": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/quality"}
    },
    "power": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "low"],
      "properties": {
        "source": {"enum": ["main", "battery", "unknown"]},
        "battery_v": {"type": ["number", "null"], "minimum": 0},
        "battery_pct": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
        "low": {"type": "boolean"}
      }
    }
  },
  "$defs": {
    "quality": {"enum": ["ok", "warming", "stale", "fault", "not_present"]}
  }
}
