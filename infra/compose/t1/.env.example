GH_SYSTEM_ID=greenhouse
GH_STALE_AFTER_S=180
GH_DEDUP_CAPACITY=2048
GH_LOG_LEVEL=INFO

# Current T1 Mosquitto permits anonymous access for the N1 lab test.
# Leave both values empty together. Production must use a dedicated account,
# ACL and TLS before deployment outside the controlled LAN.
GH_MQTT_USERNAME=
GH_MQTT_PASSWORD=
