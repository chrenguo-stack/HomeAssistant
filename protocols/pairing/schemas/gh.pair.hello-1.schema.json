{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hahub.top/schemas/gh.pair.hello-1.schema.json",
  "title": "Greenhouse pairing hello v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "pairing_id",
    "pairing_epoch",
    "hardware_id",
    "model",
    "fw_version",
    "node_nonce",
    "capabilities",
    "sent_at_ms"
  ],
  "properties": {
    "schema": {"const": "gh.pair.hello/1"},
    "pairing_id": {"type": "string", "format": "uuid"},
    "pairing_epoch": {"type": "integer", "minimum": 1, "maximum": 4294967295},
    "hardware_id": {
      "type": "string",
      "pattern": "^ghw-[a-z0-9]+-[0-9a-f]{12}$",
      "maxLength": 64
    },
    "model": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$"
    },
    "fw_version": {"type": "string", "minLength": 1, "maxLength": 64},
    "node_nonce": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]{43}$",
      "description": "Exactly 32 random bytes encoded as unpadded base64url."
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{0,63}$"
      }
    },
    "sent_at_ms": {"type": "integer", "minimum": 0}
  }
}
